<section class="wa-why wa-section--bleed" aria-labelledby="wa-why-title">
  <div class="wa-container">
    <div class="wa-why__head">
      <span class="wa-eyebrow">Why Weird Artist</span>
      <h2 id="wa-why-title" class="wa-why__title">Three things we don&rsquo;t do.</h2>
    </div>

    <div class="wa-why__grid">
      <article class="wa-why-cell">
        <div class="wa-why-cell__stat wa-mono">$0/mo</div>
        <h3 class="wa-why-cell__label">No subscriptions</h3>
        <p class="wa-why-cell__desc">
          Pay once. Use the tool for the next decade. We don&rsquo;t need
          recurring revenue to justify our existence.
        </p>
      </article>

      <article class="wa-why-cell">
        <div class="wa-why-cell__stat wa-mono">100%</div>
        <h3 class="wa-why-cell__label">Local-first</h3>
        <p class="wa-why-cell__desc">
          Your data, your machine. No cloud sync, no telemetry, no analytics
          ping when you launch the app.
        </p>
      </article>

      <article class="wa-why-cell">
        <div class="wa-why-cell__stat wa-mono">∞</div>
        <h3 class="wa-why-cell__label">Yours forever</h3>
        <p class="wa-why-cell__desc">
          When we shut down, your tool keeps working. No license server
          kill-switch. Open formats, your files.
        </p>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WA Why",
  "tag": "section",
  "class": "wa-section--bleed",
  "settings": [],
  "presets": [{ "name": "WA Why" }]
}
{% endschema %}
