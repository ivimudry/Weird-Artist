<footer class="wa-footer wa-section--bleed" role="contentinfo">
  <div class="wa-container">
    <div class="wa-footer__grid">

      <div class="wa-footer__brand">
        <a href="{{ routes.root_url }}" class="wa-footer__brand-row" aria-label="Weird Artist вЂ” home">
          {%- render 'wa-logo-mono' -%}
          <span class="wa-footer__brand-name">Weird Artist</span>
        </a>
        <p class="wa-footer__blurb">
          {{ 'wa.footer.blurb' | t }}
        </p>

        {%- if localization.available_languages.size > 1 -%}
          <div class="wa-footer__locale">
            <span class="wa-footer__locale-label">{{ 'wa.language_label' | t }}</span>
            {%- form 'localization', class: 'wa-locale-form' -%}
              <select
                class="wa-locale-select"
                name="locale_code"
                aria-label="{{ 'wa.language_label' | t }}"
                onchange="this.form.submit()"
              >
                {%- for lang in localization.available_languages -%}
                  <option value="{{ lang.iso_code }}" lang="{{ lang.iso_code }}"{% if lang.iso_code == localization.language.iso_code %} selected{% endif %}>
                    {{ lang.endonym_name | capitalize }}
                  </option>
                {%- endfor -%}
              </select>
            {%- endform -%}
          </div>
        {%- endif -%}
      </div>

      <div>
        <h4 class="wa-footer__col-title">{{ 'wa.footer.products' | t }}</h4>
        <ul class="wa-footer__list">
          <li><a href="/pages/promptgrid">PromptGrid</a></li>
          <li><a href="/pages/tools">{{ 'wa.footer.all_tools' | t }}</a></li>
          <li><a href="/pages/contact#request" style="color: var(--wa-text-muted);">{{ 'wa.footer.upcoming' | t }}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="wa-footer__col-title">{{ 'wa.footer.company' | t }}</h4>
        <ul class="wa-footer__list">
          <li><a href="/pages/about">{{ 'wa.nav.about' | t }}</a></li>
          <li><a href="/pages/contact#request">{{ 'wa.footer.request_a_tool' | t }}</a></li>
          <li><a href="/pages/contact">{{ 'wa.nav.contact' | t }}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="wa-footer__col-title">{{ 'wa.footer.legal' | t }}</h4>
        <ul class="wa-footer__list">
          <li><a href="/pages/privacy">{{ 'wa.footer.privacy' | t }}</a></li>
          <li><a href="/pages/terms">{{ 'wa.footer.terms' | t }}</a></li>
          <li><a href="/pages/refund-policy">{{ 'wa.footer.refund' | t }}</a></li>
        </ul>
      </div>

    </div>

    <div class="wa-footer__bottom">
      <div class="wa-footer__copy">
        © {{ 'now' | date: '%Y' }} Weird Artist · {{ 'wa.tagline' | t }}
      </div>
      <div class="wa-footer__social">
        <a class="wa-button-icon" href="https://github.com/" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.18-.02-2.14-3.2.69-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
        </a>
        <a class="wa-button-icon" href="https://x.com/" target="_blank" rel="noopener" aria-label="X / Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21l-6.55 7.486L22 22h-6.93l-4.59-6.01L4.97 22H2.21l7.02-8.024L2 2h7.07l4.16 5.51L18.244 2Zm-2.43 18h1.69L8.27 4H6.45l9.364 16Z"/></svg>
        </a>
        <a class="wa-button-icon" href="mailto:hello@weirdartist.io" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m4 7 8 6 8-6"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "WA Footer",
  "tag": "section",
  "class": "wa-section--bleed",
  "settings": [],
  "presets": [{ "name": "WA Footer" }],
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
