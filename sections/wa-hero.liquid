<section class="wa-hero wa-section--bleed" aria-labelledby="wa-hero-title">
  <div class="wa-aurora" aria-hidden="true">
    <div class="wa-aurora__blob"></div>
  </div>
  <div class="wa-grain" aria-hidden="true"></div>

  <div class="wa-container wa-hero__inner">
    <div class="wa-hero__content">
      <span class="wa-eyebrow">{{ 'wa.hero.eyebrow' | t }}</span>
      <h1 id="wa-hero-title" class="wa-hero__title" style="margin-top: var(--wa-space-5);">
        <span>{{ 'wa.hero.title_a' | t }}</span>
        <span class="wa-gradient-text">{{ 'wa.hero.title_b' | t }}</span>
      </h1>
      <p class="wa-hero__subtitle">
        {{ 'wa.hero.subtitle' | t }}
      </p>
      <div class="wa-hero__ctas">
        <a href="{{ routes.collections_url }}/all" class="wa-button-primary">{{ 'wa.cta.browse_tools' | t }}</a>
        <a href="/pages/about" class="wa-button-ghost">{{ 'wa.cta.read_manifesto' | t }}</a>
      </div>
    </div>

    <div class="wa-hero__preview" aria-hidden="true">
      <div class="wa-app-window">
        <div class="wa-app-window__bar">
          <div class="wa-app-window__lights"><span></span><span></span><span></span></div>
          <div class="wa-app-window__title">PromptGrid · campaign-spring-26.pgx</div>
          <div style="width: 36px;"></div>
        </div>
        <div class="wa-app-window__body">
          <div class="wa-app-line wa-app-line--w-30"></div>
          <div class="wa-app-line wa-app-line--tall wa-app-line--gradient"></div>
          <div class="wa-app-line wa-app-line--w-90"></div>
          <div class="wa-app-line wa-app-line--w-70"></div>
          <div class="wa-app-line wa-app-line--w-50"></div>
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap: var(--wa-space-3);">
            <div class="wa-app-line wa-app-line--tall"></div>
            <div class="wa-app-line wa-app-line--tall"></div>
          </div>
          <div class="wa-app-line wa-app-line--w-30"></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "WA Hero",
  "tag": "section",
  "class": "wa-section--bleed",
  "settings": [],
  "presets": [{ "name": "WA Hero" }]
}
{% endschema %}
