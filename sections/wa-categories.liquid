<section class="wa-categories wa-section--bleed" aria-labelledby="wa-categories-title">
  <div class="wa-container">
    <div class="wa-categories__head">
      <span class="wa-eyebrow">Two universes, one workshop</span>
      <h2 id="wa-categories-title" class="wa-categories__title">Pick your tools</h2>
    </div>
    <div class="wa-categories__grid">

      <a href="/pages/crm-marketing" class="wa-category-card">
        <span class="wa-category-card__glyph" aria-hidden="true">CRM</span>
        <h3 class="wa-category-card__name">CRM &amp; Marketing</h3>
        <p class="wa-category-card__desc">
          Email builders, segmentation helpers, campaign exporters —
          for the people who actually press send.
        </p>
        <span class="wa-category-card__link">View tools</span>
      </a>

      <a href="/pages/finance-trading" class="wa-category-card">
        <span class="wa-category-card__glyph" aria-hidden="true">FIN</span>
        <h3 class="wa-category-card__name">Finance &amp; Trading</h3>
        <p class="wa-category-card__desc">
          Local P/L analyzers, exchange CSV crunchers, journal tools —
          for traders who don&rsquo;t want their broker to know.
        </p>
        <span class="wa-category-card__link">View tools</span>
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "WA Categories",
  "tag": "section",
  "class": "wa-section--bleed",
  "settings": [],
  "presets": [{ "name": "WA Categories" }]
}
{% endschema %}
