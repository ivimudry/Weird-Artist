<section class="wa-request wa-section--bleed" aria-labelledby="wa-request-title">
  <div class="wa-aurora" aria-hidden="true">
    <div class="wa-aurora__blob"></div>
  </div>
  <div class="wa-grain" aria-hidden="true"></div>

  <div class="wa-request__inner">
    <span class="wa-eyebrow" style="justify-content:center;">Open requests</span>
    <h2 id="wa-request-title" class="wa-request__title" style="margin-top: var(--wa-space-4);">
      Need a tool that <span class="wa-gradient-text">doesn&rsquo;t exist yet?</span>
    </h2>
    <p class="wa-request__subtitle">
      Tell us what to build. If 10 people want the same thing, we&rsquo;ll build it.
    </p>
    <a href="/pages/contact#request" class="wa-button-primary">Submit a request</a>
  </div>
</section>

{% schema %}
{
  "name": "WA Request CTA",
  "tag": "section",
  "class": "wa-section--bleed",
  "settings": [],
  "presets": [{ "name": "WA Request CTA" }]
}
{% endschema %}
